                <div id="dlBar" style="height:100%;width:0%;border-radius:100px;background:linear-gradient(to right,${dailyColors.primary},${dailyColors.secondary});transition:width 0.3s ease;"></div>
            </div>
            <div id="dlPercent" style="font-size:14px;font-weight:600;color:${dailyColors.primary};margin-bottom:6px;">0%</div>
            <div id="dlStatus" style="font-size:12px;color:#6b7280;">Starting download...</div>
        </div>
    `;
    document.body.appendChild(overlay);

        // Animate progress bar (real download happens via browser)
    let pct = 0;
    document.getElementById('dlStatus').textContent = 'Connecting to server...';

    const interval = setInterval(() => {
        pct = Math.min(pct + (Math.random() * 2 + 0.3), 95);
        document.getElementById('dlBar').style.width = Math.round(pct) + '%';
        document.getElementById('dlPercent').textContent = Math.round(pct) + '%';
        if (pct < 20) document.getElementById('dlStatus').textContent = 'Connecting...';
        else if (pct < 60) document.getElementById('dlStatus').textContent = 'Downloading ' + app.title + '...';
        else if (pct < 90) document.getElementById('dlStatus').textContent = 'Saving file...';
        else document.getElementById('dlStatus').textContent = 'Almost done...';
        if (pct >= 95) clearInterval(interval);
    }, 400);

    const fileSize = parseFloat(app.size) || 5;
    const downloadTime = Math.max(8000, fileSize * 1500);

    const a = document.createElement('a');
    a.href = app.downloadUrl;
    a.download = app.title.replace(/\s+/g,'_') + '.apk';
    a.target = '_blank';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    setTimeout(() => {
        clearInterval(interval);
        document.getElementById('dlBar').style.width = '100%';
        document.getElementById('dlPercent').textContent = '100%';
        document.getElementById('dlStatus').textContent = '✅ Download complete! Opening file...';
        setTimeout(() => {
            overlay.remove();
            window.open(app.downloadUrl, '_blank');
        }, 1500);
    }, downloadTime);
 }
        
        
        
