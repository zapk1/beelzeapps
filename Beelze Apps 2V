async function uploadAdImageToImgBB(file) {
    const base64 = await new Promise(resolve => {
        const reader = new FileReader();
        reader.onload = e => resolve(e.target.result.split(',')[1]);
        reader.readAsDataURL(file);
    });
    const form = new FormData();
    form.append('key', IMGBB_API_KEY);
    form.append('image', base64);
    const res = await fetch('https://api.imgbb.com/1/upload', { method: 'POST', body: form });
    const data = await res.json();
    if (data.success) return data.data.url;
    throw new Error('ImgBB upload failed');
}

async function saveAds() {
    localStorage.setItem('beelzeads', JSON.stringify(ads));
    const snap = await db.collection('beelzeAds').get();
    const batch = db.batch();
    snap.docs.forEach(d => batch.delete(d.ref));
    await batch.commit();
    for (const ad of ads) {
        const { id, ...adData } = ad;
        await db.collection('beelzeAds').add(adData);
    }
}

function handleAdClick(ad) {
    if (!ad.lead) return;
    const lead = ad.lead.trim();
    if (lead.startsWith('http')) window.open(lead, '_blank');
    else if (lead.startsWith('+') || /^\d/.test(lead)) window.open(`https://wa.me/${lead.replace(/\D/g,'')}`, '_blank');
    else if (lead.includes('@')) window.location.href = `mailto:${lead}`;
}


