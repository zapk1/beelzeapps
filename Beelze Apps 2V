async function uploadApkToGitHub(file, appTitle) {
    const statusEl = document.getElementById('filePickedInfo');
    statusEl.style.display = 'block';
    statusEl.style.color = '#1d4ed8';
    statusEl.style.background = '#eff6ff';

    // Convert file to base64
    statusEl.textContent = '📦 Preparing APK...';
    const base64 = await new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = e => resolve(e.target.result.split(',')[1]);
        reader.readAsDataURL(file);
    });

    const fileName = appTitle.replace(/\s+/g, '_') + '_' + Date.now() + '.apk';
    const path = `uploads/${fileName}`;

    statusEl.textContent = 'Uploading to BeelzeApps ';

    const res = await fetch(`https://api.github.com/repos/${GITHUB_REPO}/contents/${path}`, {
        method: 'PUT',
        headers: {
            'Authorization': `Bearer ${GITHUB_TOKEN}`,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            message: `Upload ${fileName}`,
            content: base64,
            branch: GITHUB_BRANCH
        })
    });

    const data = await res.json();
    if (!data.content || !data.content.download_url) {
        throw new Error('GitHub upload failed: ' + (data.message || 'unknown error'));
    }

    statusEl.textContent = '✅ APK uploaded to BeelzeApps !';
    statusEl.style.color = '#059669';
    statusEl.style.background = '#ecfdf5';

    return data.content.download_url;
}






